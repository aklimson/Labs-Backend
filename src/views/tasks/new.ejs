<h1>Create task</h1>

<form method="POST" action="/tasks">
  <p>
    <label>Title<br />
      <input name="title" required />
    </label>
  </p>
  <p>
    <label>Description<br />
      <textarea name="description" rows="4"></textarea>
    </label>
  </p>

  <button type="submit">Create</button>
  <a href="/tasks">Cancel</a>
</form>