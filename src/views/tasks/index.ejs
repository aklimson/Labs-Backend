<h1>Tasks</h1>

<p><a href="/tasks/new">➕ Create new task</a></p>

<% if (!tasks || tasks.length === 0) { %>
  <p>No tasks yet.</p>
<% } else { %>
  <table>
    <thead>
      <tr>
        <th>ID</th><th>Title</th><th>Completed</th><th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% tasks.forEach(t => { %>
        <tr>
          <td><%= t.id %></td>
          <td><a href="/tasks/<%= t.id %>"><%= t.title %></a></td>
          <td><%= t.completed ? "✅" : "❌" %></td>
          <td>
            <a href="/tasks/<%= t.id %>/edit">Edit</a>
            <form method="POST" action="/tasks/<%= t.id %>/delete" style="display:inline">
              <button type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>